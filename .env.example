# Copy this file to .env and fill in your values.
# Never commit .env or any file containing real secrets.

# ----- Required -----

# Base URL of your wger instance (no trailing slash)
WGER_BASE_URL=https://wger.example.com

# ----- Token (choose one method) -----

# Option 1 (recommended for Docker): mount a file as a secret.
# In docker-compose.yml:
#   volumes:
#     - ./secrets/wger_api_token.txt:/run/secrets/wger_api_token:ro
# The app will automatically read /run/secrets/wger_api_token.

# Option 2: point to any file containing the token.
# WGER_API_TOKEN_FILE=/path/to/wger_token.txt

# Option 3: set the token directly as an env var (least preferred).
# WGER_API_TOKEN=your_token_here

# ----- Optional -----

# Display name for your hero character
HERO_NAME=Hero

# Environment label (development | production)
APP_ENV=production

# Override the database path (default: /data/wger_hero.db inside container)
# DATABASE_URL=sqlite:////data/wger_hero.db
